   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Parallax background with early morning nature</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Parallax background with early morning nature landscape with green field with pond, grass, rocks and conifers under pink sky with crescent, 2d layers for game animation, Cartoon vector illustration</rdf:li>
    </rdf:Alt>
   </dc:description>
